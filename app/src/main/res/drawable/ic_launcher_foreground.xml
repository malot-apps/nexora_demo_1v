<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    
    <!-- Beautiful geometric premium "N" logo with custom gradient -->
    <path
        android:pathData="M32,28 L46,28 L66,70 L66,28 L76,28 L76,80 L62,80 L42,38 L42,80 L32,80 Z"
        android:fillType="nonZero">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="32"
                android:startY="28"
                android:endX="76"
                android:endY="80"
                android:type="linear">
                <!-- Neon Cyan (AppColors.primary) -->
                <item android:color="#00E5FF" android:offset="0.0"/>
                <!-- Electric Blue (AppColors.secondary) -->
                <item android:color="#2979FF" android:offset="1.0"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Glowing futuristic play button triangle in the center-right of the N -->
    <path
        android:pathData="M48,44 L48,64 L64,54 Z"
        android:fillColor="#80FFFFFF"
        android:strokeWidth="1.5"
        android:strokeColor="#00E5FF" />
</vector>

