<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.MyApplication" parent="android:Theme.DeviceDefault.NoActionBar">
        <!-- Prevent white flashes during cold start by matching Nexora's brand color -->
        <item name="android:windowBackground">#0F0F12</item>
        <item name="android:statusBarColor">#0F0F12</item>
        <item name="android:navigationBarColor">#0F0F12</item>

        <!-- Android 12+ SplashScreen configurations -->
        <item name="android:windowSplashScreenBackground" tools:targetApi="s">#0F0F12</item>
        <item name="android:windowSplashScreenAnimatedIcon" tools:targetApi="s">@drawable/ic_launcher_foreground</item>
        <item name="android:windowSplashScreenIconBackgroundColor" tools:targetApi="s">#0F0F12</item>
    </style>
</resources>

